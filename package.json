{
    "name": "charity-unified",
    "version": "1.0.0",
    "description": "Unified startup for Charity app",
    "scripts": {
        "install-all": "npm install && cd back-end && npm install && cd ../front-end && npm install",
        "dev:backend": "cd back-end && npm run dev",
        "dev:frontend": "cd front-end && npm run dev",
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "build": "cd front-end && npm install --legacy-peer-deps && npm run build"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.1.5",
        "multer": "^2.0.2",
        "nodemailer": "^7.0.12",
        "stripe": "^20.2.0"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}