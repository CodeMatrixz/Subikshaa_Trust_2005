{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "front-end/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/back-end/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/front-end/dist/$1"
    }
  ]
}